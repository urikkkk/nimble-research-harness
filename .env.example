# Nimble API
NIMBLE_API_KEY=your_nimble_api_key_here
NIMBLE_BASE_URL=https://sdk.nimbleway.com/v1

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: default model override
NRH_MODEL=claude-sonnet-4-6

# Optional: session storage directory
NRH_SESSIONS_DIR=.research_sessions

# Optional: WSA catalog cache TTL in seconds (default 3600)
NRH_WSA_CACHE_TTL=3600

# Optional: log level
NRH_LOG_LEVEL=INFO
